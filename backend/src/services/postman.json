{
  "info": {
    "name": "MedMate API",
    "description": "MedMate API test collection. Base URL is stored in the {{baseUrl}} variable. The {{token}} variable is automatically saved after a successful login.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/v1",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string",
      "description": "JWT token — auto-saved after login"
    },
    {
      "key": "userId",
      "value": "",
      "type": "string",
      "description": "Logged in user ID — auto-saved after login"
    },
    {
      "key": "verificationToken",
      "value": "",
      "type": "string",
      "description": "Paste this manually from your email after registering"
    },
    {
      "key": "resetToken",
      "value": "",
      "type": "string",
      "description": "Paste this manually from your reset email"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "Registration, email verification, login and password reset flows.",
      "item": [
        {
          "name": "Register — Patient",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Marie Dupont\",\n  \"email\": \"marie@example.com\",\n  \"password\": \"securepassword123\",\n  \"role\": \"patient\",\n  \"preferred_language\": \"fr\",\n  \"city\": \"Yaoundé\"\n}"
            },
            "description": "Registers a new patient account. A verification email is sent to the provided address. The account cannot log in until the email is verified."
          }
        },
        {
          "name": "Register — Caregiver",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Paul Biya\",\n  \"email\": \"paul@example.com\",\n  \"password\": \"securepassword123\",\n  \"role\": \"caregiver\",\n  \"preferred_language\": \"fr\",\n  \"city\": \"Douala\"\n}"
            },
            "description": "Registers a new caregiver account. Same flow as patient — verification email required before login."
          }
        },
        {
          "name": "Verify Email",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/verify-email?token={{verificationToken}}",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "verify-email"],
              "query": [{ "key": "token", "value": "{{verificationToken}}" }]
            },
            "description": "Verifies a user's email address. Copy the token from the verification email and paste it into the {{verificationToken}} collection variable, then run this request."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.status === 'success') {",
                  "  pm.collectionVariables.set('token', res.data.token);",
                  "  pm.collectionVariables.set('userId', res.data.user.id);",
                  "  console.log('Token and userId saved to collection variables');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"marie@example.com\",\n  \"password\": \"securepassword123\"\n}"
            },
            "description": "Logs in a verified user. On success the JWT token is automatically saved to {{token}} and the user ID to {{userId}} so all subsequent requests can use them."
          }
        },
        {
          "name": "Login — Unverified (expect 401)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"unverified@example.com\",\n  \"password\": \"securepassword123\"\n}"
            },
            "description": "Expects a 401 EMAIL_NOT_VERIFIED error. Use this to confirm the guard works."
          }
        },
        {
          "name": "Login — Wrong Password (expect 401)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"marie@example.com\",\n  \"password\": \"wrongpassword\"\n}"
            },
            "description": "Expects a 401 INVALID_CREDENTIALS error. Confirms the wrong password guard works."
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/auth/forgot-password", "host": ["{{baseUrl}}"], "path": ["auth", "forgot-password"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"marie@example.com\"\n}"
            },
            "description": "Sends a password reset email. Always returns the same success message whether or not the email exists — this prevents email enumeration attacks."
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/reset-password?token={{resetToken}}",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "reset-password"],
              "query": [{ "key": "token", "value": "{{resetToken}}" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"password\": \"newSecurePassword456\"\n}"
            },
            "description": "Resets the user's password. Copy the token from the reset email and paste it into the {{resetToken}} collection variable, then run this request. Token expires after 1 hour."
          }
        },
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "http://localhost:3000/health", "host": ["http://localhost:3000"], "path": ["health"] },
            "description": "Confirms the API server is running. No auth required."
          }
        }
      ]
    }
  ]
}